layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="https://github.com/dj95/zjstatus/releases/latest/download/zjstatus.wasm" {
                format_left   "{mode} {command_user_info} #[fg=4]{session}"
                format_center "{tabs}"
                format_right  "{command_battery} {datetime}"
                format_space  ""

                border_enabled  "false"
                border_char     "─"
                border_format   "#[fg=#6C7086]{char}"
                border_position "top"

                mode_normal  "#[bg=4] {name} #[fg=4]"
                mode_pane  "#[bg=1] {name} #[fg=1]"
                mode_locked    "#[fg=0]█"
                mode_default_to_mode "pane"

                tab_normal   "#[fg=8]#[bg=8] {name} #[fg=8]"
                tab_active   "#[fg=4]#[bg=4,bold,italic] {name} #[fg=4]"

                command_user_info_command     "bash -c \"echo $(whoami)@$(hostname)\""
                command_user_info_format      "#[fg=4,bold] {stdout} "
                command_user_info_interval    "0"
                command_user_info_rendermode  "static"

                command_battery_command     "sh -c 'line=$(pmset -g batt | tail -1 | cut -f2 | cut -d\";\" -f1,2 | tr \";\" \" \" | tr -s \" \"); pct=$(printf \"%s\" \"$line\" | cut -d\" \" -f1 | tr -d \"%\"); state=$(printf \"%s\" \"$line\" | cut -d\" \" -f2-); case \"$state\" in charging) suffix=\" \" ;; \"AC attached\") suffix=\"  AC\" ;; *) suffix=\"\" ;; esac; if [ \"$pct\" -le 10 ]; then color=1; elif [ \"$pct\" -le 25 ]; then color=3; else color=8; fi; printf \"#[fg=%s] %s%%%s \" \"$color\" \"$pct\" \"$suffix\"'"
                command_battery_format      "{stdout}"
                command_battery_interval    "30"
                command_battery_rendermode  "dynamic"

                datetime        "#[fg=8,bold] {format} "
                datetime_format "%H:%M"
                datetime_timezone "America/Phoenix"
            }
        }
    }
}
